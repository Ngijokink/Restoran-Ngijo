        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res  = pm.response.json();",
                  "const data = res.data;",
                  "if (!data) { console.log('No data field'); return; }",
                  "const tokenMap = {",
                  "    superadmin_token : 'token_superadmin',",
                  "    admin_token      : 'token_admin',",
                  "    manager_token    : 'token_manager',",
                  "    staff_token      : 'token_staff',",
                  "    user_token       : 'token_user',",
                  "};",
                  "for (const [key, envVar] of Object.entries(tokenMap)) {",
                  "    if (data[key]) {",
                  "        pm.environment.set(envVar, data[key]);",
                  "        console.log(`✅ ${envVar} berhasil di-set`);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"user@gmail.com\",\n    \"password\": \"12345678\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}api/login",
