          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Postman → Tests tab (di request Login)\r",
                  "\r",
                  "const res  = pm.response.json();\r",
                  "const data = res.data;\r",
                  "\r",
                  "if (!data) {\r",
                  "    console.log(\"Response tidak punya field data\");\r",
                  "    return;\r",
                  "}\r",
                  "\r",
                  "const tokenMap = {\r",
                  "    superadmin_token : \"token_superadmin\",\r",
                  "    admin_token      : \"token_admin\",\r",
                  "    manager_token    : \"token_manager\",\r",
                  "    staff_token      : \"token_staff\",\r",
                  "    user_token       : \"token_user\",\r",
                  "};\r",
                  "\r",
                  "let tokenSet = false;\r",
                  "\r",
                  "for (const [key, envVar] of Object.entries(tokenMap)) {\r",
                  "    if (data[key]) {\r",
                  "        pm.environment.set(envVar, data[key]);\r",
                  "        console.log(`✅ ${envVar} berhasil di-set`);\r",
                  "        tokenSet = true;\r",
                  "    }\r",
                  "}\r",
                  "\r",
                  "if (!tokenSet) {\r",
                  "    console.warn(\"⚠️ Tidak ada token yang ditemukan di response\");\r",
                  "}"
                ],
